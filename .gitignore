# Git ignore rules

# OS files
.DS_Store
Thumbs.db

# Editor/IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build artifacts
dist/
build/
*.egg-info/
__pycache__/
*.pyc
*.class

# Dependencies
node_modules/
vendor/
*.lock

# Environment & secrets
.env
.env.local
*.pem
*.key
secrets.json

# Temporary files
tmp/
temp/
*.tmp

# Keep .gitkeep files from being ignored
docs/.gitkeep
artifacts/.gitkeep
ideas/.gitkeep
sessions/.gitkeep
src/.gitkeep
